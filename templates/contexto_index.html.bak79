}

/* ══ SCROLLBAR DEL MODAL ══ */
#fund-modal::-webkit-scrollbar { width: 5px; }
#fund-modal::-webkit-scrollbar-track { background: #1a1f2e; }
#fund-modal::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }

/* ══ TODOS LOS ESTILOS DEL PANEL FUNDAMENTAL ══ */
#fund-modal .fund-card {
  background: #1a1f2e;
  color: #e0e0e0;
  font-family: 'Segoe UI', system-ui, sans-serif;
}

#fund-modal .fund-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 18px;
  clear: both;
}
#fund-modal .fund-header.muy_solida { background: linear-gradient(135deg,#1a3a2a,#1e4d35); border-left: 4px solid #28a745; }
#fund-modal .fund-header.solida     { background: linear-gradient(135deg,#1a2a3a,#1e3a55); border-left: 4px solid #3b9ede; }
#fund-modal .fund-header.neutra     { background: linear-gradient(135deg,#3a3010,#4d4020); border-left: 4px solid #f0c040; }
