#fund-modal .score-bar-wrapper { background: #161b27; padding: 12px 18px; border-bottom: 1px solid rgba(255,255,255,0.06); }
#fund-modal .score-bar-label { display: flex; justify-content: space-between; font-size: 0.72rem; color: #666; margin-bottom: 5px; }
#fund-modal .score-bar-bg { height: 7px; background: #2a2a3a; border-radius: 4px; overflow: hidden; }
#fund-modal .score-bar-fill { height: 100%; border-radius: 4px; }
#fund-modal .score-bar-fill.muy_solida { background: linear-gradient(90deg,#28a745,#5dd882); }
#fund-modal .score-bar-fill.solida     { background: linear-gradient(90deg,#3b9ede,#60d0ff); }
#fund-modal .score-bar-fill.neutra     { background: linear-gradient(90deg,#f0a030,#f0c040); }
#fund-modal .score-bar-fill.debil      { background: linear-gradient(90deg,#dc3545,#f06060); }

#fund-modal .fund-motivos { background: #161b27; padding: 10px 14px; display: flex; flex-wrap: wrap; gap: 6px; border-bottom: 1px solid rgba(255,255,255,0.06); }
#fund-modal .motivo-tag { font-size: 0.72rem; padding: 3px 8px; border-radius: 20px; font-weight: 500; }
#fund-modal .motivo-tag.ok      { background: rgba(40,167,69,0.18);  color: #5dd882; border: 1px solid rgba(40,167,69,0.3); }
#fund-modal .motivo-tag.ko      { background: rgba(220,53,69,0.18);  color: #f06060; border: 1px solid rgba(220,53,69,0.3); }
#fund-modal .motivo-tag.neutral { background: rgba(240,192,64,0.15); color: #f0c040; border: 1px solid rgba(240,192,64,0.3); }

#fund-modal .nota-banco { background: rgba(59,158,222,0.1); border: 1px solid rgba(59,158,222,0.25); border-radius: 6px; padding: 7px 12px; font-size: 0.74rem; color: #60b3f0; margin: 10px 14px; }

#fund-modal .fund-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(255,255,255,0.06); }
#fund-modal .fund-seccion { background: #161b27; padding: 12px 14px; }
#fund-modal .fund-seccion h4 { font-size: 0.64rem; text-transform: uppercase; letter-spacing: 1.5px; color: #666; margin-bottom: 10px; padding-bottom: 5px; border-bottom: 1px solid rgba(255,255,255,0.06); }

#fund-modal .ratio-item { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
#fund-modal .ratio-item:last-child { border-bottom: none; }
#fund-modal .ratio-label { font-size: 0.76rem; color: #999; }
#fund-modal .ratio-value { font-size: 0.82rem; font-weight: 700; }
#fund-modal .ratio-value.ok   { color: #5dd882; }
#fund-modal .ratio-value.warn { color: #f0a030; }
#fund-modal .ratio-value.bad  { color: #f06060; }
#fund-modal .ratio-value.na   { color: #444; font-weight: 400; }

#fund-modal .fund-footer { background: #161b27; padding: 8px 14px; display: flex; justify-content: space-between; font-size: 0.68rem; color: #555; border-top: 1px solid rgba(255,255,255,0.06); }
</style>
<script>
// ══ DRAG & DROP DEL MODAL FUNDAMENTAL ══
(function() {
  const modal = document.getElementById('fund-modal');
  let isDragging = false;
  let startX, startY, startLeft, startTop;

  // Cabecera como zona de arrastre
  const handle = document.createElement('div');
  handle.style.cssText = `
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    height: 28px;
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    cursor: grab;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10001;
    user-select: none;
  `;
  handle.innerHTML = `<span style="color:#444;font-size:18px;letter-spacing:3px">⠿⠿⠿</span>`;
  modal.insertBefore(handle, modal.firstChild);

  handle.addEventListener('mousedown', function(e) {
    isDragging = true;

    // Si el modal estaba centrado con transform, convertir a posición absoluta
    const rect = modal.getBoundingClientRect();
    modal.style.right   = 'auto';
    modal.style.bottom  = 'auto';
    modal.style.top     = rect.top + 'px';
    modal.style.left    = rect.left + 'px';
    modal.style.transform = 'none';

    startX    = e.clientX;
    startY    = e.clientY;
    startLeft = rect.left;
    startTop  = rect.top;

    handle.style.cursor = 'grabbing';
    e.preventDefault();
  });

  document.addEventListener('mousemove', function(e) {
    if (!isDragging) return;

    const dx = e.clientX - startX;
    const dy = e.clientY - startY;

    let newLeft = startLeft + dx;
    let newTop  = startTop  + dy;

    // Límites para no salir de la pantalla
    const maxLeft = window.innerWidth  - modal.offsetWidth  - 8;
    const maxTop  = window.innerHeight - 60;

    newLeft = Math.max(8, Math.min(newLeft, maxLeft));
    newTop  = Math.max(8, Math.min(newTop,  maxTop));

    modal.style.left = newLeft + 'px';
    modal.style.top  = newTop  + 'px';
  });

  document.addEventListener('mouseup', function() {
    if (isDragging) {
      isDragging = false;
      handle.style.cursor = 'grab';
    }
  });
})();
</script>

<script>
    function abrirFundamental() {
      const sel = document.getElementById('ctx-fund-ticker');
      if (!sel) { alert('No se encontró selector de ticker'); return; }
      const ticker = sel.value;
      if (!ticker) { alert('Selecciona un ticker primero'); return; }
      document.getElementById('fund-modal').style.display   = 'block';
      document.getElementById('fund-spinner').style.display = 'block';
      document.getElementById('fund-contenido').innerHTML   = '';
      fetch(`/analisis/modal/fundamental/${ticker}`)
        .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.text(); })
        .then(html => {
            document.getElementById('fund-spinner').style.display = 'none';
            document.getElementById('fund-contenido').innerHTML = html;
            document.getElementById('fund-contenido').querySelectorAll('script').forEach(s => {
                const ns = document.createElement('script');
                ns.textContent = s.textContent;
                document.body.appendChild(ns);
            });
        })
        .catch(err => {
            document.getElementById('fund-spinner').style.display = 'none';
            document.getElementById('fund-contenido').innerHTML = `
                <div style="padding:40px;text-align:center;color:#f06060;background:#1a1f2e;border-radius:12px;">
                  ❌ Error al cargar datos de <strong>${ticker}</strong><br>
                  <small style="color:#666">${err.message}</small>
                </div>`;
        });
    }
    function cerrarFundamental() {
      document.getElementById('fund-modal').style.display   = 'none';
      document.getElementById('fund-contenido').innerHTML   = '';
      document.getElementById('fund-spinner').style.display = 'block';
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') cerrarFundamental(); });
</script>

<!-- ══ MODAL DEFINICIONES ANÁLISIS FUNDAMENTAL ══ -->
<div id="modalDefFund" style="
    display:none; position:fixed; top:0; left:0; width:100%; height:100%;
    background:rgba(0,0,0,0.7); z-index:9999; overflow-y:auto; padding:20px;
    box-sizing:border-box;">
  <div style="max-width:780px; margin:30px auto; background:#fff; border-radius:12px;
      box-shadow:0 20px 60px rgba(0,0,0,0.3); overflow:hidden;">

    <!-- Cabecera -->
    <div style="display:flex;align-items:center;justify-content:space-between;
        padding:18px 24px; background:linear-gradient(135deg,#1e293b,#334155);
        color:white;">
      <div>
        <div style="font-size:1.1em;font-weight:700;">📖 Glosario — Análisis Fundamental</div>
        <div style="font-size:0.78em;color:#94a3b8;margin-top:2px;">
          Ratios e indicadores del análisis financiero
        </div>
      </div>
      <button onclick="cerrarDefFund()" style="
          background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);
          color:white;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:0.9em;">
        ✕ Cerrar
      </button>
    </div>

    <!-- Contenido -->
    <div id="defFundContent" style="padding:20px 24px;"></div>

    <!-- Pie -->
    <div style="padding:12px 24px;background:#f8fafc;border-top:1px solid #e2e8f0;
        font-size:0.75em;color:#94a3b8;text-align:center;">
      Fuente: Datos financieros anuales · yfinance / FMP · Actualizado al cargar
    </div>
  </div>
</div>

<script>
const DEF_FUND = [
  // VALORACIÓN
  { cat: "💰 Valoración", badge: "PER",
    nombre: "Price to Earnings Ratio — Precio/Beneficio",
    def: "Cuántas veces el mercado paga los beneficios actuales de la empresa. PER = Precio / BPA (Beneficio por Acción).",
    uso: "PER < 12: barato. PER 12-20: razonable. PER > 25: caro o alto crecimiento esperado. Limitación: no comparable entre sectores distintos ni válido si hay pérdidas." },

  { cat: "💰 Valoración", badge: "EV/EBITDA",
    nombre: "Enterprise Value / EBITDA",
    def: "Compara el valor total de la empresa (deuda + capitalización) con su beneficio operativo antes de amortizaciones. Es el ratio de adquisición preferido por los analistas profesionales.",
    uso: "< 10x: barato. 10-20x: razonable. > 20x: caro (salvo utilities/renovables donde 25x puede ser normal). Ventaja sobre PER: incluye la deuda y es comparable entre sectores." },

  { cat: "💰 Valoración", badge: "P/BV",
    nombre: "Price to Book Value — Precio/Valor Contable",
    def: "Compara el precio de mercado con el valor contable (activos − pasivos) por acción.",
    uso: "P/BV < 1: el mercado valora la empresa por debajo de su valor contable (puede ser oportunidad o trampa de valor). Útil en bancos y aseguradoras. Poco relevante en empresas tecnológicas o de servicios." },

  { cat: "💰 Valoración", badge: "P/V",
    nombre: "Precio / Ventas (P/Sales)",
    def: "Capitalización bursátil dividida entre los ingresos totales anuales.",
    uso: "Útil cuando la empresa no tiene beneficios (startups, turnaround). < 1x: muy barato. > 5x: se paga caro por cada euro de ventas. Mejor usado junto a margen neto." },

  // RENTABILIDAD
  { cat: "⭐ Rentabilidad", badge: "ROE",
    nombre: "Return on Equity — Rentabilidad sobre Fondos Propios",
    def: "Beneficio neto dividido entre el patrimonio neto. Mide cuánto gana la empresa por cada euro que tienen los accionistas.",
    uso: "> 15%: excelente. 8-15%: bueno. < 8%: bajo. Trampa: una empresa muy endeudada puede tener ROE alto artificialmente (el equity es pequeño). Siempre cruzar con Deuda/EBITDA." },

  { cat: "⭐ Rentabilidad", badge: "ROA",
    nombre: "Return on Assets — Rentabilidad sobre Activos",
    def: "Beneficio neto dividido entre los activos totales. Mide la eficiencia con que la empresa usa todos sus recursos.",
    uso: "> 5%: bueno. > 10%: excelente. Menos sensible al apalancamiento que el ROE. Útil para comparar empresas del mismo sector independientemente de su estructura de capital." },

  { cat: "⭐ Rentabilidad", badge: "M.NETO",
    nombre: "Margen Neto",
    def: "Beneficio neto dividido entre los ingresos totales. Porcentaje de cada euro de ventas que se convierte en beneficio final.",
    uso: "Varía mucho por sector. Distribución: 1-3%. Tecnología: 15-30%. Utilities: 10-20%. Lo importante es la tendencia — margen creciente es positivo, decreciente es señal de alerta." },

  { cat: "⭐ Rentabilidad", badge: "M.OPER",
    nombre: "Margen Operativo (EBIT)",
    def: "Beneficio operativo (antes de intereses e impuestos) dividido entre ingresos. Mide la rentabilidad del negocio puro sin efectos financieros ni fiscales.",
    uso: "Más estable que el margen neto. Si el margen operativo es alto pero el neto es bajo, la empresa tiene un problema financiero (exceso de deuda) no operativo." },

  // SOLVENCIA
  { cat: "🏛️ Solvencia", badge: "D/EBITDA",
    nombre: "Deuda Neta / EBITDA",
    def: "Cuántos años de beneficio operativo necesita la empresa para pagar toda su deuda. Es el principal indicador de salud financiera.",
    uso: "< 2x: muy sólido. 2-3x: normal. 3-5x: elevado, requiere atención. > 5x: preocupante. Excepción: utilities e infraestructuras pueden operar con 5-7x por la estabilidad de sus flujos." },

  { cat: "🏛️ Solvencia", badge: "D/EQ",
    nombre: "Deuda / Equity (Apalancamiento)",
    def: "Deuda total dividida entre el patrimonio neto. Cuánta deuda tiene la empresa por cada euro de recursos propios.",
    uso: "< 50%: conservador. 50-100%: normal. > 150%: elevado. En sectores financieros (bancos) este ratio no es directamente aplicable por la naturaleza del negocio." },

  { cat: "🏛️ Solvencia", badge: "CURR",
    nombre: "Current Ratio — Ratio Corriente",
    def: "Activo corriente dividido entre pasivo corriente. Mide la capacidad de la empresa para pagar sus deudas a corto plazo.",
    uso: "> 2: muy holgado. 1.5-2: bueno. 1-1.5: ajustado. < 1: el pasivo corriente supera al activo corriente — riesgo de liquidez. Complementar con Quick Ratio para más precisión." },

  // CRECIMIENTO
  { cat: "📈 Crecimiento", badge: "CAGR",
    nombre: "CAGR — Tasa de Crecimiento Anual Compuesto",
    def: "Tasa de crecimiento constante que llevaría a los ingresos o beneficios desde su valor inicial al final en N años.",
    uso: "CAGR ingresos > 10%: empresa en crecimiento. CAGR BPA > 15%: crecimiento fuerte. Se usa en ventanas de 3 y 5 años para identificar tendencias reales eliminando la volatilidad anual." },

  { cat: "📈 Crecimiento", badge: "BPA",
    nombre: "BPA — Beneficio Por Acción (EPS)",
    def: "Beneficio neto total dividido entre el número de acciones en circulación. Mide cuánto gana la empresa por cada acción.",
    uso: "BPA creciente = empresa que crea valor. BPA decreciente = señal de alerta. El BPA Forward usa estimaciones del próximo año — si es mayor que el trailing, el mercado espera mejora." },

  // FCF
  { cat: "💵 Flujo de Caja", badge: "FCF",
    nombre: "Free Cash Flow — Flujo de Caja Libre",
    def: "Caja generada por las operaciones del negocio menos las inversiones de capital (CAPEX). Es el dinero real que queda disponible para la empresa.",
    uso: "FCF positivo consistente = negocio sano que genera caja real. FCF negativo puntual puede ser por inversión. FCF negativo crónico con beneficios positivos = beneficios contables, no reales. El FCF es más difícil de manipular que el beneficio neto." },

  // DIVIDENDO
  { cat: "🎁 Dividendo", badge: "YIELD",
    nombre: "Dividend Yield — Rentabilidad por Dividendo",
    def: "Dividendo anual por acción dividido entre el precio. Porcentaje de retorno solo por dividendos.",
    uso: "> 5%: alto, atractivo para inversión en renta. 2-5%: moderado. < 2%: bajo, la empresa reinvierte en crecimiento. Yield muy alto puede indicar caída del precio (trampa de dividendo)." },

  { cat: "🎁 Dividendo", badge: "PAYOUT",
    nombre: "Payout Ratio — Ratio de Distribución",
    def: "Porcentaje del beneficio neto que se destina a pagar dividendos.",
    uso: "< 50%: sostenible, la empresa retiene capital para crecer. 50-70%: razonable. > 80%: poco margen de seguridad, el dividendo puede estar en riesgo si el beneficio cae. > 100%: insostenible." },

  // ANALISTAS
  { cat: "👥 Analistas", badge: "P.OBJ",
    nombre: "Precio Objetivo de Consenso",
    def: "Media de los precios objetivos fijados por los analistas que cubren el valor. Refleja la valoración fundamental que los profesionales asignan al activo.",
    uso: "Upside > 20%: el mercado descuenta pesimismo que los analistas no comparten. Downside: el mercado valora más que los analistas — posible sobrecompra. Siempre complementar con tu propio análisis técnico." },
];

function abrirDefFund() {
    const modal = document.getElementById('modalDefFund');
    const cont  = document.getElementById('defFundContent');
    modal.style.display = 'block';

    // Agrupar por categoría
    const cats = {};
    DEF_FUND.forEach(d => {
        if (!cats[d.cat]) cats[d.cat] = [];
        cats[d.cat].push(d);
    });

    let html = '';
    Object.entries(cats).forEach(([cat, items]) => {
        html += `<div style="margin-bottom:20px;">
            <div style="font-size:0.78em;font-weight:700;color:#64748b;text-transform:uppercase;
                letter-spacing:0.8px;margin-bottom:10px;padding-bottom:6px;
                border-bottom:2px solid #e2e8f0;">${cat}</div>`;
        items.forEach(d => {
            html += `<div style="margin-bottom:12px;padding:12px 14px;background:#f8fafc;
                border-radius:8px;border-left:3px solid #6366f1;">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <span style="background:#1e293b;color:#e2e8f0;padding:2px 8px;border-radius:4px;
                        font-size:0.72em;font-weight:700;letter-spacing:0.5px;">${d.badge}</span>
                    <span style="font-weight:600;font-size:0.88em;color:#1e293b;">${d.nombre}</span>
                </div>
                <div style="font-size:0.83em;color:#475569;margin-bottom:5px;">${d.def}</div>
                <div style="font-size:0.80em;color:#6366f1;font-style:italic;">
                    💡 ${d.uso}
                </div>
            </div>`;
        });
        html += '</div>';
    });
    cont.innerHTML = html;
}

function cerrarDefFund() {
    document.getElementById('modalDefFund').style.display = 'none';
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') cerrarDefFund();
});
document.addEventListener('DOMContentLoaded', () => {
    const m = document.getElementById('modalDefFund');
    if (m) m.addEventListener('click', e => { if (e.target === m) cerrarDefFund(); });
});

// ═══════════════════════════════════════════════
// BLOQUE 4: ANALYTICS
// ═══════════════════════════════════════════════
async function cargarAnalytics() {
    const sistema = document.getElementById('analytics-sistema').value;
    const spin = document.getElementById('analytics-spinner');
    const err  = document.getElementById('analytics-error');
    const cont = document.getElementById('analytics-contenido');
    
    spin.style.display = 'block';
    err.style.display = 'none';
    cont.style.display = 'none';
    
    try {
        const params = sistema ? `?sistema=${sistema}` : '';
        const r = await fetch(`/contexto/analytics/kpis${params}`);
        const data = await r.json();
        
        if (!data.success) throw new Error(data.error || 'Error cargando KPIs');
        
        const kpis = data.kpis;
        
        // Warning si muestra pequeña
        let warningHTML = '';
        if (kpis.total_trades < 20) {
            warningHTML = `<div style="background:#fef3c7;border-left:3px solid #f59e0b;padding:10px;margin-bottom:16px;border-radius:4px;font-size:.85rem;color:#92400e">
                ⚠️ Muestra pequeña (${kpis.total_trades} trades). Resultados no concluyentes. Mínimo recomendado: 20 trades.
            </div>`;
        }
        
        cont.innerHTML = `
            ${warningHTML}
            
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:20px">
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid #3b82f6">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">Total Trades</div>
                    <div style="font-size:1.4rem;font-weight:700;color:#e2e8f0">${kpis.total_trades}</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid ${kpis.winrate >= 50 ? '#16a34a' : kpis.winrate >= 40 ? '#f59e0b' : '#dc2626'}">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">Winrate</div>
                    <div style="font-size:1.4rem;font-weight:700;color:${kpis.winrate >= 50 ? '#22c55e' : kpis.winrate >= 40 ? '#fbbf24' : '#ef4444'}">${kpis.winrate.toFixed(1)}%</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid ${kpis.expectancy > 0.3 ? '#16a34a' : kpis.expectancy > 0 ? '#f59e0b' : '#dc2626'}">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">Expectancy</div>
                    <div style="font-size:1.4rem;font-weight:700;color:${kpis.expectancy > 0.3 ? '#22c55e' : kpis.expectancy > 0 ? '#fbbf24' : '#ef4444'}">${kpis.expectancy >= 0 ? '+' : ''}${kpis.expectancy.toFixed(2)}R</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid ${kpis.profit_factor >= 1.5 ? '#16a34a' : kpis.profit_factor >= 1 ? '#f59e0b' : '#dc2626'}">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">Profit Factor</div>
                    <div style="font-size:1.4rem;font-weight:700;color:${kpis.profit_factor >= 1.5 ? '#22c55e' : kpis.profit_factor >= 1 ? '#fbbf24' : '#ef4444'}">${kpis.profit_factor.toFixed(2)}</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid #10b981">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">R Medio ↗</div>
                    <div style="font-size:1.4rem;font-weight:700;color:#22c55e">+${kpis.r_medio_ganador.toFixed(2)}R</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid #dc2626">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">R Medio ↘</div>
                    <div style="font-size:1.4rem;font-weight:700;color:#ef4444">-${Math.abs(kpis.r_medio_perdedor).toFixed(2)}R</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid #3b82f6">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">R Mejor</div>
                    <div style="font-size:1.4rem;font-weight:700;color:#22c55e">+${kpis.r_mejor.toFixed(2)}R</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid #3b82f6">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">R Peor</div>
                    <div style="font-size:1.4rem;font-weight:700;color:#ef4444">${kpis.r_peor.toFixed(2)}R</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid ${kpis.r_total > 0 ? '#16a34a' : '#dc2626'}">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">R Total</div>
                    <div style="font-size:1.4rem;font-weight:700;color:${kpis.r_total > 0 ? '#22c55e' : '#ef4444'}">${kpis.r_total >= 0 ? '+' : ''}${kpis.r_total.toFixed(2)}R</div>
                </div>
                <div style="background:#0f172a;padding:12px;border-radius:8px;border-left:3px solid #f59e0b">
                    <div style="font-size:.75rem;color:#94a3b8;margin-bottom:4px">Max DD</div>
                    <div style="font-size:1.4rem;font-weight:700;color:#fbbf24">${kpis.max_drawdown.toFixed(2)}R</div>
                </div>
            </div>
            
            <div style="margin-top:24px">
                <h3 style="font-size:.95rem;color:#e2e8f0;margin-bottom:12px">📈 Curva de Equity (R acumulado)</h3>
                <canvas id="equity-chart" style="max-height:200px"></canvas>
            </div>
        `;
        
        // Renderizar gráfico
        renderEquityChart(kpis.curva_equity);
        
        spin.style.display = 'none';
        cont.style.display = 'block';
        
    } catch (error) {
        console.error('Error analytics:', error);
        spin.style.display = 'none';
        err.textContent = '❌ Error cargando analytics: ' + error.message;
        err.style.display = 'block';
    }
}

function renderEquityChart(curva) {
    const ctx = document.getElementById('equity-chart');
    if (!ctx) return;
    
    if (window.equityChart) {
        window.equityChart.destroy();
    }
    
    const color = curva[curva.length - 1] >= 0 ? '#22c55e' : '#ef4444';
    
    window.equityChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: curva.map((_, i) => i + 1),
            datasets: [{
                label: 'R Acumulado',
                data: curva,
                borderColor: color,
                backgroundColor: color + '20',
                borderWidth: 2,
                tension: 0.1,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    ticks: { color: '#94a3b8' },
                    grid: { color: '#334155' }
                },
                x: {
                    ticks: { color: '#94a3b8' },
                    grid: { color: '#334155' }
                }
            }
        }
    });
}
</script>

</body>
</html>