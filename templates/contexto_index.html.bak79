#fund-modal .calidad-texto { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; margin-top: 3px; }
#fund-modal .muy_solida .calidad-texto { color: #5dd882; }
#fund-modal .solida     .calidad-texto { color: #60b3f0; }
#fund-modal .neutra     .calidad-texto { color: #f0c040; }
