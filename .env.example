# .env.example
# ══════════════════════════════════════════════════════════════
# CONFIGURACIÓN MIWEB TRADING
# ══════════════════════════════════════════════════════════════

# Copia este archivo a .env y rellena los valores

# ══════════════════════════════════════════════════════════════
# API KEY DE ANTHROPIC (para análisis IA)
# ══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=tu_api_key_aqui

# ══════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE EMAIL PARA ALERTAS
# ══════════════════════════════════════════════════════════════

# OPCIÓN 1: Usar Gmail (RECOMENDADO)
# ──────────────────────────────────────────────────────────────
# 1. Ve a: https://myaccount.google.com/apppasswords
# 2. Genera una "Contraseña de Aplicación"
# 3. Usa ESA contraseña aquí (NO tu contraseña normal de Gmail)

EMAIL_REMITENTE=tu_email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# OPCIÓN 2: Outlook/Hotmail
# ──────────────────────────────────────────────────────────────
# EMAIL_REMITENTE=tu_email@outlook.com
# EMAIL_PASSWORD=tu_contraseña
# SMTP_SERVER=smtp-mail.outlook.com
# SMTP_PORT=587

# OPCIÓN 3: Yahoo Mail
# ──────────────────────────────────────────────────────────────
# EMAIL_REMITENTE=tu_email@yahoo.com
# EMAIL_PASSWORD=tu_contraseña
# SMTP_SERVER=smtp.mail.yahoo.com
# SMTP_PORT=587

# ══════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ══════════════════════════════════════════════════════════════

# 📧 Email de destino: salva.mugica@gmail.com (hardcoded)
#    Para cambiarlo: edita alertas/notificaciones.py línea 14

# ⚡ Las alertas se envían automáticamente cuando:
#    - Haces click en "⚡ Verificar ahora"
#    - El precio cruza el nivel configurado

# 🔒 Gmail requiere "Contraseña de Aplicación":
#    https://support.google.com/accounts/answer/185833
